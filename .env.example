# Copy this file to .env.local and fill in real values. Never commit .env.local.
# See SECURITY.md for best practices.

# --- QDay / Abelian (required for Abelian Award) ---
NEXT_PUBLIC_QDAY_RPC=https://testnet-rpc-00.qday.info
NEXT_PUBLIC_QDAY_CHAIN_ID=35443
NEXT_PUBLIC_QDAY_EXPLORER=https://testnet-explorer.qday.info

# --- AWS Bedrock (Contract Analyzer & Collective Pool agents) ---
# Create IAM user with Bedrock permissions; use least-privilege keys.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ID_CONTRACT=
BEDROCK_AGENT_ID_POOL=
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=

# Optional: direct model fallback if agents not configured
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# --- Optional: contract addresses (after deployment) ---
# NEXT_PUBLIC_ESCROW_ADDRESS=0x...
# NEXT_PUBLIC_LEGAL_FUND_ADDRESS=0x...
